<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/css/bootstrap.ejs') %>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Homepage</title>
</head>

<body>
    <%- include('./partials/components/nav.ejs') %>

        <div class="container my-5">
            <div>
                <% if (locals.user && user.role==='Admin' ) { %>
                    <a class="btn btn-danger" href="/blog/delete/<%= blog._id %>">Delete Blog</a>
                    <% } %>
            </div>
            <img width="60%" src="/uploads/<%= blog.coverimage %>" class="rounded mx-auto d-block">
            <h1 class="my-5 text-center">
                <%= blog.title %>
            </h1>
            <p>
                <%= blog.content %>
            </p>
            <p>Posted By: <%= blog.createdBy.fullName %>
            </p>
        </div>
        <div class="container">
            <h5>Comments (<%= comments.length %>)</h5>
            <% comments.forEach(comment=> { %>
                <div class="py-3 border-top border-bottom">
                    <h6 class="mb-2">
                        <%= comment.createdBy.fullName %>
                    </h6>
                    <p class="mb-2">
                        <%= comment.content %>
                    </p>
                    <small class="text-muted">
                        <%= comment.createdAt.toLocaleDateString("en-IN", { day: "2-digit" , month: "2-digit" ,
                            year: "numeric" }) %>
                    </small>
                </div>
                <% }) %>
        </div>
        <% if (locals.user) { %>
            <div class="container my-5">
                <input id="comment-input" class="form-control" type="text" placeholder="Enter your comment...">
                <button onclick="postComment()" class="btn btn-success my-3">Post</button>
            </div>
            <% } %>
                <%- include('./partials/js/bootstrap.ejs') %>
                    <script>
                        const blogId = "<%= blog._id %>"
                        const input = document.getElementById('comment-input')

                        function postComment() {
                            fetch('/comment/create', {
                                method: 'POST',
                                headers: {
                                    "Content-Type": 'application/json'
                                },
                                body: JSON.stringify({ blogId, content: input.value })
                            })
                                .then(e => window.location.reload())
                        }
                    </script>
</body>

</html>