<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/css/bootstrap.ejs') %>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Homepage</title>
</head>

<body>
    <%- include('./partials/components/nav.ejs') %>

        <div class="container">
            <div class="row mt-5">

                <% blogs.forEach(blog=> { %>

                    <div class="col-md-4 mb-4">
                        <div class="card h-100">

                            <img src="/uploads/<%= blog.coverimage %>" class="card-img-top"
                                style="height: 200px; object-fit: cover;">

                            <div class="card-body">
                                <h5 class="card-title">
                                    <%= blog.title %>
                                </h5>
                                <p>
                                    <%= blog.views %> views
                                </p>
                                <a href="/blog/view/<%= blog._id %>" class="btn btn-primary">
                                    View
                                </a>
                            </div>

                        </div>
                    </div>

                    <% }) %>

            </div>
        </div>

        <%- include('./partials/js/bootstrap.ejs') %>
</body>

</html>